  <script>
    // Accordion toggle
    function toggleTopic(btn) {
      const topic = btn.closest('.topic');
      const wasOpen = topic.classList.contains('open');

      // Close all topics in the same module (optional: comment out for multi-open)
      // topic.closest('.module').querySelectorAll('.topic.open').forEach(t => {
      //   t.classList.remove('open');
      //   t.querySelector('.topic-trigger').setAttribute('aria-expanded', 'false');
      // });

      if (!wasOpen) {
        topic.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
      } else {
        topic.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
      }
    }

    // Sticky TOC active state on scroll
    const modules = document.querySelectorAll('.module');
    const tocLinks = document.querySelectorAll('.toc-item a');

    function updateTOC() {
      let current = '';
      modules.forEach(mod => {
        const rect = mod.getBoundingClientRect();
        if (rect.top <= 160) {
          current = mod.id;
        }
      });
      tocLinks.forEach(link => {
        link.classList.toggle('active', link.getAttribute('href') === '#' + current);
      });
    }

    // Throttled scroll listener
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          updateTOC();
          ticking = false;
        });
        ticking = true;
      }
    });

    // Nav scroll effect
    const nav = document.getElementById('topNav');
    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 20);
    });
  </script>

    entities: ["Google Shopping","Merchant Center","Shopify","BigCommerce","Magento","WooCommerce","Salesforce Commerce","Channable","DataFeedWatch","Feedonomics","GoDataFeed","Productsup","ChannelAdvisor","Bazaarvoice","Salsify","Akeneo","CommerceHub","Mirakl","Marketplacer","Shopware","PrestaShop","Wix","Squarespace"]
  }
};

// Shared across all domains (signal type and sentiment are domain-agnostic)
var SIGNAL_KEYWORDS={deal:["acquire","acquisition","merger","acqui","bought","purchase","deal","$","million","billion","funding","invest","raise"],partnership:["partner","collaborat","integrat","alliance","team up","join force","agreement"],product_launch:["launch","unveil","introduc","debut","announc","new feature","new platform","release","rollout","roll out"],earnings:["earnings","revenue","quarter","q1","q2","q3","q4","profit","growth","fiscal","financial result"],regulation:["regulat","legislation","antitrust","ftc","sec filing","compliance","govern","congress","senate","eu ","policy"],research:["study","research","report","survey","forecast","analysis","data show","according to","emarketer","forrester","gartner"],opinion:["opinion","editorial","perspective","column","think","commentary","outlook"],trend:["trend","shift","emerging","growing","accelerat","future of","evolution","next wave"]};
var SENTIMENT_POS=["growth","surge","boost","record","accelerat","gain","opportunity","expand","success","strong","positive","leading","innovati","breakthrough"];
var SENTIMENT_NEG=["decline","drop","fall","challenge","threat","concern","risk","struggle","cut","loss","layoff","slow","pullback","uncertain"];

function extractURLs(t){return(t.match(/https?:\/\/[^\s<>"{}|\\^`\[\](),]+/g)||[]).map(function(u){return u.replace(/[.),;:!?]+$/,"");});}

// Unwrap Google redirect URLs to get the real destination
function unwrapGoogleUrl(url) {
  try {
    var u = new URL(url);
    if (u.hostname.indexOf("google.") > -1 && u.pathname === "/url") {
      var realUrl = u.searchParams.get("url") || u.searchParams.get("q");
      if (realUrl && realUrl.indexOf("http") === 0) return decodeURIComponent(realUrl);
    }
    return url;
  } catch(e) { return url; }
}

// Filter out non-article URLs
function isJunkUrl(url) {
  try {
    var u = new URL(url);
    var host = u.hostname.toLowerCase();
    var path = u.pathname.toLowerCase();
    // All remaining google.com links after unwrapping are junk (share, feedback, alerts UI, etc.)
    if (host.indexOf("google.") > -1) return true;
    // Google infrastructure
    if (host.indexOf("googleapis.com") > -1) return true;
    if (host.indexOf("gstatic.com") > -1) return true;
    if (host.indexOf("googleusercontent.com") > -1) return true;
    if (host.indexOf("doubleclick.") > -1) return true;
    if (host.indexOf("googlesyndication.") > -1) return true;
    if (host.indexOf("googleadservices.") > -1) return true;
    if (host.indexOf("google-analytics.") > -1) return true;
    // Asset files
    if (/\.(jpg|jpeg|png|gif|svg|ico|css|js|woff|woff2|ttf|eot)$/i.test(path)) return true;
    // Unsubscribe / preferences
    if (path.indexOf("unsubscribe") > -1 || path.indexOf("/preferences") > -1) return true;
    return false;
  } catch(e) { return true; }
}

function parseURL(url){try{var u=new URL(url);return{domain:u.hostname.replace("www.",""),slug:(u.pathname.replace(/\/$/,"").split("/").filter(function(s){return s.length>0;}).pop()||"").replace(/[-_]/g," ").replace(/[0-9]{6,}/g," ").trim(),url:url};}catch(e){return null;}}
function inferTitle(slug,domain){if(!slug)return"Article from "+domain;return slug.charAt(0).toUpperCase()+slug.slice(1);}
// Match themes across all domains; returns { themes: [...], domains: [...] }
function matchAllThemes(t) {
  var lower = t.toLowerCase();
  var allThemes = [];
  var matchedDomains = [];
  var domainKeys = Object.keys(DOMAINS);
  for (var d = 0; d < domainKeys.length; d++) {
    var domainId = domainKeys[d];
    var domainThemes = DOMAINS[domainId].themes;
    var domainMatched = false;
    var themeKeys = Object.keys(domainThemes);
    for (var i = 0; i < themeKeys.length; i++) {
      var kws = domainThemes[themeKeys[i]];
      for (var j = 0; j < kws.length; j++) {
        if (lower.indexOf(kws[j]) > -1) {
          if (allThemes.indexOf(themeKeys[i]) === -1) allThemes.push(themeKeys[i]);
          domainMatched = true;
          break;
        }
      }
    }
    if (domainMatched && matchedDomains.indexOf(domainId) === -1) {
      matchedDomains.push(domainId);
    }
  }
  // Default to retail-media if nothing matched
  if (allThemes.length === 0) { allThemes = ["retail media"]; matchedDomains = ["retail-media"]; }
  return { themes: allThemes, domains: matchedDomains };
}

// Match entities across all domains; returns flat array
function matchAllEntities(t) {
  var found = [];
  var seen = {};
  var domainKeys = Object.keys(DOMAINS);
  for (var d = 0; d < domainKeys.length; d++) {
    var ents = DOMAINS[domainKeys[d]].entities;
    for (var i = 0; i < ents.length; i++) {
      if (!seen[ents[i]] && (t.indexOf(ents[i]) > -1 || t.toLowerCase().indexOf(ents[i].toLowerCase()) > -1)) {
        found.push(ents[i]);
        seen[ents[i]] = true;
      }
    }
  }
  return found;
}

// Signal and sentiment matching — shared across domains
function matchSignal(t){var l=t.toLowerCase(),best="trend",bs=0;Object.keys(SIGNAL_KEYWORDS).forEach(function(k){var sc=0;SIGNAL_KEYWORDS[k].forEach(function(w){if(l.indexOf(w)>-1)sc++;});if(sc>bs){bs=sc;best=k;}});return best;}
function matchSentiment(t){var l=t.toLowerCase(),p=0,n=0;SENTIMENT_POS.forEach(function(w){if(l.indexOf(w)>-1)p++;});SENTIMENT_NEG.forEach(function(w){if(l.indexOf(w)>-1)n++;});return p>n?"positive":n>p?"negative":"neutral";}

function localAnalyze(rawText) {
  var rawUrls = extractURLs(rawText);
  var articles = [];

  // Phase 1: Unwrap Google redirects, then filter junk
  var cleanUrls = [];
  rawUrls.forEach(function(url) {
    var unwrapped = unwrapGoogleUrl(url);
    if (!isJunkUrl(unwrapped)) {
      cleanUrls.push({ original: url, clean: unwrapped });
    }
  });

  // Phase 2: Analyze each clean URL with domain-aware matching
  cleanUrls.forEach(function(entry) {
    var p = parseURL(entry.clean);
    if (!p) return;
    var idx = rawText.indexOf(entry.original);
    var ctx = p.slug + " " + p.domain + " " + rawText.slice(Math.max(0, idx - 250), Math.min(rawText.length, idx + entry.original.length + 250));
    var themeResult = matchAllThemes(ctx);
    var ents = matchAllEntities(ctx);
    articles.push({
      id: newId(), title: inferTitle(p.slug, p.domain), source: p.domain, url: entry.clean,
      themes: themeResult.themes, domains: themeResult.domains,
      signal_type: matchSignal(ctx), sentiment: matchSentiment(ctx),
      entities: ents, significance: Math.min(5, Math.max(1, themeResult.themes.length + ents.length - 1))
    });
  });

  if (articles.length === 0 && rawText.trim().length > 20) {
    var themeResult = matchAllThemes(rawText);
    articles.push({id:newId(),title:rawText.slice(0,60).replace(/\n/g," ").trim()+"...",source:"pasted text",url:"",themes:themeResult.themes,domains:themeResult.domains,signal_type:matchSignal(rawText),sentiment:matchSentiment(rawText),entities:matchAllEntities(rawText),significance:2});
  }
  var seen = {}, out = [];
  articles.forEach(function(a) { var k = a.url || a.title; if (!seen[k]) { seen[k] = true; out.push(a); } });
  return out;
}

function synthesize(sessions) {
  var tc={},ec={},sn={positive:0,negative:0,neutral:0},sc={},dc={},total=0;
  sessions.forEach(function(s){(s.articles||[]).forEach(function(a){
    total++;
    sn[a.sentiment]=(sn[a.sentiment]||0)+1;
    sc[a.signal_type]=(sc[a.signal_type]||0)+1;
    (a.themes||[]).forEach(function(t){tc[t]=(tc[t]||0)+1;});
    (a.entities||[]).forEach(function(e){ec[e]=(ec[e]||0)+1;});
    (a.domains||[]).forEach(function(d){dc[d]=(dc[d]||0)+1;});
  });});
  return{themeCount:tc,entityCount:ec,sentiments:sn,signalCounts:sc,domainCount:dc,totalArticles:total};
}


// Base64url decode (Gmail uses URL-safe base64)
function b64Decode(str) {
  if (!str) return "";
  var padded = str.replace(/-/g, "+").replace(/_/g, "/");
  while (padded.length % 4 !== 0) padded += "=";
  try { return decodeURIComponent(escape(atob(padded))); }
  catch(e) { try { return atob(padded); } catch(e2) { return ""; } }
}

// Extract text content from a Gmail message payload
function extractEmailContent(payload) {
  var text = "";

  function walk(part) {
    if (!part) return;
    var mime = (part.mimeType || "").toLowerCase();
    // Prefer text/html for richer link extraction, fall back to text/plain
    if ((mime === "text/html" || mime === "text/plain") && part.body && part.body.data) {
      text += b64Decode(part.body.data) + "\n";
    }
    if (part.parts) {
      part.parts.forEach(walk);
    }
  }

  walk(payload);

  // Strip HTML tags but preserve href URLs
  text = text.replace(/<a[^>]+href=["']([^"']+)["'][^>]*>/gi, " $1 ");
  text = text.replace(/<[^>]+>/g, " ");
  text = text.replace(/&amp;/g, "&").replace(/&lt;/g, "<").replace(/&gt;/g, ">").replace(/&quot;/g, '"').replace(/&#39;/g, "'").replace(/&nbsp;/g, " ");
  text = text.replace(/\s+/g, " ").trim();

  return text;
}

async function gmailFetchAlerts(token, maxResults) {
  // Search for Google Alert emails
  var searchUrl = "https://gmail.googleapis.com/gmail/v1/users/me/messages?q=" +
    encodeURIComponent("from:googlealerts-noreply@google.com") +
    "&maxResults=" + (maxResults || 10);

  var searchRes = await fetch(searchUrl, {
    headers: { Authorization: "Bearer " + token }
  });
  if (!searchRes.ok) throw new Error("Gmail search failed: " + searchRes.status);
  var searchData = await searchRes.json();
  var messageIds = (searchData.messages || []).map(function(m) { return m.id; });

  if (messageIds.length === 0) return { content: "", count: 0 };

  // Fetch each message's content and track email dates
  var allContent = "";
  var fetched = 0;
  var emailDates = [];
  for (var i = 0; i < messageIds.length; i++) {
    var msgRes = await fetch(
      "https://gmail.googleapis.com/gmail/v1/users/me/messages/" + messageIds[i] + "?format=full",
      { headers: { Authorization: "Bearer " + token } }
    );
    if (msgRes.ok) {
      var msg = await msgRes.json();
      var content = extractEmailContent(msg.payload);
      if (content.length > 10) {
        allContent += content + "\n\n---\n\n";
        fetched++;
        // Track the email's actual date
        if (msg.internalDate) {
          emailDates.push(new Date(parseInt(msg.internalDate)).toISOString());
        }
      }
    }
  }

  // Determine content date range from email dates
  emailDates.sort();
  var contentDate = emailDates.length > 0 ? emailDates[Math.floor(emailDates.length / 2)] : null;
  var dateRange = emailDates.length > 0 ? { earliest: emailDates[0], latest: emailDates[emailDates.length - 1] } : null;

  return { content: allContent, count: fetched, contentDate: contentDate, dateRange: dateRange };
}


var gdriveState = { tokenClient: null, accessToken: null };

// Wait for Google Identity Services to load
function ensureGoogleLoaded() {
  return new Promise(function(resolve, reject) {
    if (window.google && window.google.accounts && window.google.accounts.oauth2) {
      resolve();
      return;
    }
    var attempts = 0;
    var poll = setInterval(function() {
      attempts++;
      if (window.google && window.google.accounts && window.google.accounts.oauth2) {
        clearInterval(poll);
        resolve();
      } else if (attempts > 50) {
        clearInterval(poll);
        reject(new Error("Google Identity Services failed to load. Check your internet connection and refresh."));
      }
    }, 100);
  });
}

function initGDrive() {
  if (gdriveState.tokenClient) return;
  gdriveState.tokenClient = google.accounts.oauth2.initTokenClient({
    client_id: GOOGLE_CLIENT_ID,
    scope: "https://www.googleapis.com/auth/drive.file",
    callback: function() {} // replaced at auth time
  });
}

function gdriveAuth() {
  return new Promise(function(resolve, reject) {
    ensureGoogleLoaded().then(function() {
      initGDrive();
      if (gdriveState.accessToken) { resolve(gdriveState.accessToken); return; }
      if (!gdriveState.tokenClient) { reject(new Error("Drive client not initialized")); return; }
      gdriveState.tokenClient.callback = function(resp) {
        if (resp.error) { reject(new Error(resp.error)); return; }
        if (resp.access_token) { gdriveState.accessToken = resp.access_token; resolve(resp.access_token); }
        else { reject(new Error("No access token received")); }
      };
      gdriveState.tokenClient.requestAccessToken({ prompt: "" });
    }).catch(reject);
  });
}

async function gdriveFindFile(token) {
  var res = await fetch("https://www.googleapis.com/drive/v3/files?q=name%3D'" + GDRIVE_FILE + "'+and+trashed%3Dfalse&spaces=drive&fields=files(id,name,modifiedTime)", {
    headers: { Authorization: "Bearer " + token }
  });
  var data = await res.json();
  return (data.files && data.files.length > 0) ? data.files[0] : null;
}

async function gdriveSave(token, store) {
  var existing = await gdriveFindFile(token);
  var body = JSON.stringify(store);
  if (existing) {
    await fetch("https://www.googleapis.com/upload/drive/v3/files/" + existing.id + "?uploadType=media", {
      method: "PATCH",
      headers: { Authorization: "Bearer " + token, "Content-Type": "application/json" },
      body: body
    });
  } else {
    var metadata = JSON.stringify({ name: GDRIVE_FILE, mimeType: "application/json" });
    var form = new FormData();
    form.append("metadata", new Blob([metadata], { type: "application/json" }));
    form.append("file", new Blob([body], { type: "application/json" }));
    await fetch("https://www.googleapis.com/upload/drive/v3/files?uploadType=multipart", {
      method: "POST",
      headers: { Authorization: "Bearer " + token },
      body: form
    });
  }
}

async function gdriveLoad(token) {
  var file = await gdriveFindFile(token);
  if (!file) return null;
  var res = await fetch("https://www.googleapis.com/drive/v3/files/" + file.id + "?alt=media", {
    headers: { Authorization: "Bearer " + token }
  });
  return await res.json();
}


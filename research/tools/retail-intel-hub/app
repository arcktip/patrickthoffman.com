function extractJSON(text) {
  if (!text) return null;
  var s = text.replace(/```json/g,"").replace(/```/g,"").trim();
  var start = s.indexOf("{"); if (start===-1) return null;
  var depth=0, end=-1;
  for (var i=start;i<s.length;i++) { if(s[i]==="{")depth++; else if(s[i]==="}"){depth--;if(depth===0){end=i;break;}} }
  if (end===-1) return null;
  try { return JSON.parse(s.slice(start,end+1)); } catch(e) { return null; }
}


function newId() { return Date.now().toString(36) + Math.random().toString(36).slice(2,7); }

function emptyStore() { return { sessions:[], trendReports:[], briefingReports:[], lastIngestDate:null, version:2 }; }

// Get effective content date for a session (contentDate if set, otherwise ingest date)
function getContentDate(session) {
  return session.contentDate || session.date;
}

// Try to extract a publication date from a URL path (e.g. /2025/12/15/article or /2025-12-article)
function extractDateFromUrl(url) {
  try {
    var path = new URL(url).pathname;
    // Pattern: /YYYY/MM/DD/ or /YYYY/MM/
    var match = path.match(/\/(\d{4})\/(\d{1,2})\/(\d{1,2})\//);
    if (match) {
      var y = parseInt(match[1]), m = parseInt(match[2]), d = parseInt(match[3]);
      if (y >= 2015 && y <= 2030 && m >= 1 && m <= 12 && d >= 1 && d <= 31) {
        return new Date(y, m - 1, d).toISOString();
      }
    }
    var match2 = path.match(/\/(\d{4})\/(\d{1,2})\//);
    if (match2) {
      var y = parseInt(match2[1]), m = parseInt(match2[2]);
      if (y >= 2015 && y <= 2030 && m >= 1 && m <= 12) {
        return new Date(y, m - 1, 15).toISOString(); // mid-month estimate
      }
    }
    // Pattern: /YYYY-MM-DD- in slug
    var match3 = path.match(/\/(\d{4})-(\d{2})-(\d{2})/);
    if (match3) {
      var y = parseInt(match3[1]), m = parseInt(match3[2]), d = parseInt(match3[3]);
      if (y >= 2015 && y <= 2030 && m >= 1 && m <= 12 && d >= 1 && d <= 31) {
        return new Date(y, m - 1, d).toISOString();
      }
    }
    return null;
  } catch(e) { return null; }
}

// Given a list of URLs, try to infer a common content date
function inferContentDateFromUrls(urls) {
  var dates = [];
  urls.forEach(function(url) {
    var d = extractDateFromUrl(url);
    if (d) dates.push(d);
  });
  if (dates.length === 0) return null;
  // Return the median date
  dates.sort();
  return dates[Math.floor(dates.length / 2)];
}

// Sort sessions by contentDate descending (most recent content first)
function sortSessions(sessions) {
  return sessions.slice().sort(function(a, b) {
    var da = new Date(getContentDate(a)).getTime();
    var db = new Date(getContentDate(b)).getTime();
    return db - da;
  });
}

function loadStore() {
  try {
    var raw = localStorage.getItem(STORE_KEY);
    if (!raw) {
      // Migrate from v1
      var oldSessions = JSON.parse(localStorage.getItem("rmi-sessions") || "null");
      if (oldSessions && oldSessions.length > 0) {
        var store = emptyStore();
        store.sessions = oldSessions.map(function(s) {
          s.articles = (s.articles||[]).map(function(a) { if (!a.id) a.id = newId(); return a; });
          return s;
        });
        saveStore(store);
        return store;
      }
      return emptyStore();
    }
    var store = JSON.parse(raw);
    // Ensure all articles have IDs
    (store.sessions||[]).forEach(function(s) {
      (s.articles||[]).forEach(function(a) { if (!a.id) a.id = newId(); });
    });
    if (!store.trendReports) store.trendReports = [];
    if (!store.briefingReports) store.briefingReports = [];
    if (!store.lastIngestDate) store.lastIngestDate = null;
    return store;
  } catch(e) { return emptyStore(); }
}

function saveStore(store) {
  try { localStorage.setItem(STORE_KEY, JSON.stringify(store)); } catch(e) {}
}

function loadSetting(key) { try { return localStorage.getItem(key) || ""; } catch(e) { return ""; } }
function saveSetting(key, val) { try { localStorage.setItem(key, val); } catch(e) {} }

// Build a Set of all URLs already ingested across all sessions
function getAllUrls(store) {
  var urls = new Set();
  (store.sessions || []).forEach(function(s) {
    (s.articles || []).forEach(function(a) {
      if (a.url && a.url.length > 0) urls.add(a.url);
    });
  });
  return urls;
}

// Dedup articles against a Set of known URLs; returns { kept:[], skipped:number }
function deduplicateArticles(articles, knownUrls) {
  var kept = [];
  var skipped = 0;
  articles.forEach(function(a) {
    if (a.url && a.url.length > 0 && knownUrls.has(a.url)) {
      skipped++;
    } else {
      kept.push(a);
      if (a.url && a.url.length > 0) knownUrls.add(a.url); // prevent intra-batch dupes too
    }
  });
  return { kept: kept, skipped: skipped };
}

// Calculate how stale the data is
function daysSinceIngest(lastIngestDate) {
  if (!lastIngestDate) return Infinity;
  var diff = Date.now() - new Date(lastIngestDate).getTime();
  return Math.floor(diff / (1000 * 60 * 60 * 24));
}


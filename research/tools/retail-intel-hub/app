  // Persist store
  function updateStore(fn) {
    setStoreState(function(prev) {
      var next = typeof fn === "function" ? fn(JSON.parse(JSON.stringify(prev))) : fn;
      saveStore(next);
      return next;
    });
  }

  // ─── Article CRUD ───
  function deleteArticle(sessionId, articleId) {
    updateStore(function(s) {
      var sess = s.sessions.find(function(x){return x.id===sessionId;});
      if (sess) {
        sess.articles = sess.articles.filter(function(a){return a.id!==articleId;});
        if (sess.articles.length === 0) {
          s.sessions = s.sessions.filter(function(x){return x.id!==sessionId;});
        }
      }
      return s;
    });
    setStatus("✓ Article removed");
  }

  function addArticle() {
    if (!addUrl && !addTitle) return;
    // Check for duplicate URL
    if (addUrl) {
      var existing = getAllUrls(store);
      if (existing.has(addUrl)) {
        setStatus("⚠ URL already exists in your intel.");
        return;
      }
    }
    var article;
    if (addUrl) {
      var analyzed = localAnalyze(addUrl);
      article = analyzed[0];
      if (addTitle) article.title = addTitle;
    } else {
      article = {id:newId(),title:addTitle,source:"manual",url:"",themes:["retail media"],domains:["retail-media"],signal_type:"trend",sentiment:"neutral",entities:[],significance:1};
    }
    // Determine content date: user-set > URL-extracted > today
    var cDate = null;
    if (contentDateInput) {
      cDate = new Date(contentDateInput + "T12:00:00").toISOString();
    } else if (addUrl) {
      cDate = extractDateFromUrl(addUrl);
    }
    var session = {id:newId(),date:new Date().toISOString(),contentDate:cDate||new Date().toISOString(),articles:[article],synthesis:null,source:"manual"};
    updateStore(function(s) { s.sessions = [session].concat(s.sessions); s.lastIngestDate = new Date().toISOString(); return s; });
    setAddUrl(""); setAddTitle(""); setContentDateInput(""); setShowAddArticle(false);
    setStatus("✓ Article added");
  }

  // ─── Analyze ───
  var handleAnalyze = useCallback(async function() {
    var trimmed = input.trim();
    if (trimmed.length < 10 || busy) return;
    setBusy(true); setStatus("Analyzing...");

    var knownUrls = getAllUrls(store);
    var localArticles = localAnalyze(trimmed);
    localArticles.forEach(function(a){if(!a.id)a.id=newId();});
    var session;
    var skipped = 0;
    var dedup;

    // Determine content date: user-set > URL-inferred > today
    var pasteContentDate;
    if (contentDateInput) {
      pasteContentDate = new Date(contentDateInput + "T12:00:00").toISOString();
    } else {
      var urlDates = inferContentDateFromUrls(extractURLs(trimmed));
      pasteContentDate = urlDates || new Date().toISOString();
    }

    if (hasKey) {
      try {
        setStatus("Running Claude analysis...");
        var rawText = await callClaude(apiKey, ANALYSIS_PROMPT + trimmed);
        var parsed = extractJSON(rawText);
        if (parsed && parsed.articles && parsed.articles.length > 0) {
          parsed.articles.forEach(function(a){a.id=newId();});
          dedup = deduplicateArticles(parsed.articles, knownUrls);
          skipped = dedup.skipped;
          if (dedup.kept.length > 0) {
            session = {id:newId(),date:new Date().toISOString(),contentDate:pasteContentDate,articles:dedup.kept,synthesis:parsed.meta_synthesis||null,source:"claude"};
          }
          setStatus("✓ "+dedup.kept.length+" new"+(skipped>0?" · "+skipped+" duplicate"+(skipped>1?"s":"")+" skipped":"")+" (Claude)");
        } else {
          dedup = deduplicateArticles(localArticles, knownUrls);
          skipped = dedup.skipped;
          if (dedup.kept.length > 0) {
            session = {id:newId(),date:new Date().toISOString(),contentDate:pasteContentDate,articles:dedup.kept,synthesis:null,source:"local"};
          }
          setStatus("✓ "+dedup.kept.length+" new"+(skipped>0?" · "+skipped+" skipped":"")+" (local fallback)");
        }
      } catch(e) {
        dedup = deduplicateArticles(localArticles, knownUrls);
        skipped = dedup.skipped;
        if (dedup.kept.length > 0) {
          session = {id:newId(),date:new Date().toISOString(),contentDate:pasteContentDate,articles:dedup.kept,synthesis:null,source:"local"};
        }
        setStatus("✓ "+dedup.kept.length+" new"+(skipped>0?" · "+skipped+" skipped":"")+" (local — "+e.message.slice(0,40)+")");
      }
    } else {
      dedup = deduplicateArticles(localArticles, knownUrls);
      skipped = dedup.skipped;
      if (dedup.kept.length > 0) {
        session = {id:newId(),date:new Date().toISOString(),contentDate:pasteContentDate,articles:dedup.kept,synthesis:null,source:"local"};
      }
      setStatus("✓ "+dedup.kept.length+" new article"+(dedup.kept.length!==1?"s":"")+(skipped>0?" · "+skipped+" duplicate"+(skipped>1?"s":"")+" skipped":"")+" (local)");

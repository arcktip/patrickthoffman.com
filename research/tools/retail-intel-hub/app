  // ─── Trends ───
  var handleTrends = useCallback(async function() {
    if (!hasKey || trendBusy || sCount === 0) return;
    setTrendBusy(true); setStatus("Synthesizing trends...");
    try {
      var syn = synthesize(sessions);
      var payload = JSON.stringify({sessions:sessions.map(function(s){return{date:getContentDate(s),articles:s.articles,synthesis:s.synthesis};}),entities:syn.entityCount,themes:syn.themeCount,domain_breakdown:syn.domainCount});
      var rawText = await callClaude(apiKey, TREND_PROMPT + payload);
      var parsed = extractJSON(rawText);
      if (parsed) {
        var report = {
          id:newId(), date:new Date().toISOString(), data:parsed,
          snapshot:{totalArticles:syn.totalArticles,totalSessions:sCount,topThemes:Object.entries(syn.themeCount).sort(function(a,b){return b[1]-a[1];}).slice(0,5),topEntities:Object.entries(syn.entityCount).sort(function(a,b){return b[1]-a[1];}).slice(0,5)}
        };
        updateStore(function(s) { s.trendReports = [report].concat(s.trendReports); return s; });
        setTrendIdx(0);
        setStatus("✓ Trend report saved");
      } else { setStatus("Could not parse trends."); }
    } catch(e) { setStatus("Trend error: "+e.message.slice(0,60)); }
    setTrendBusy(false);
  }, [hasKey, trendBusy, sessions, sCount, apiKey]);

  // ─── Generate Briefing ───
  var handleBriefing = useCallback(async function() {
    if (!hasKey || briefingBusy || sCount === 0) return;
    setBriefingBusy(true); setStatus("Generating briefing...");
    try {
      var syn = synthesize(sessions);
      var payload = JSON.stringify({
        total_sessions: sCount,
        total_articles: syn.totalArticles,
        date_range: { earliest: getContentDate(sessions[sessions.length - 1]), latest: getContentDate(sessions[0]) },
        sessions: sessions.map(function(s) {
          return { date: getContentDate(s), source: s.source, articles: s.articles.map(function(a) {
            return { title: a.title, source: a.source, url: a.url, summary: a.summary || "", themes: a.themes, signal_type: a.signal_type, sentiment: a.sentiment, entities: a.entities, strategic_insight: a.strategic_insight || "" };
          })};
        }),
        accumulated_themes: Object.entries(syn.themeCount).sort(function(a,b){return b[1]-a[1];}),
        accumulated_entities: Object.entries(syn.entityCount).sort(function(a,b){return b[1]-a[1];}),
        sentiment_breakdown: syn.sentiments,
        signal_breakdown: syn.signalCounts,
        domain_breakdown: syn.domainCount
      });
      var rawText = await callClaude(apiKey, BRIEFING_PROMPT + payload);
      var parsed = extractJSON(rawText);
      if (parsed) {
        var report = {
          id: newId(), date: new Date().toISOString(), data: parsed,
          snapshot: { totalArticles: syn.totalArticles, totalSessions: sCount, topThemes: Object.entries(syn.themeCount).sort(function(a,b){return b[1]-a[1];}).slice(0,5), topEntities: Object.entries(syn.entityCount).sort(function(a,b){return b[1]-a[1];}).slice(0,5) }
        };
        updateStore(function(s) { s.briefingReports = [report].concat(s.briefingReports || []); return s; });
        setBriefingIdx(0);
        setStatus("✓ Briefing generated");
      } else { setStatus("Could not parse briefing."); }
    } catch(e) { setStatus("Briefing error: " + e.message.slice(0, 60)); }
    setBriefingBusy(false);
  }, [hasKey, briefingBusy, sessions, sCount, apiKey]);

  // ─── Google Drive ───
  var handleGDriveSave = useCallback(async function() {
    setGdriveBusy(true); setStatus("Saving to Google Drive...");
    try {
      await gdriveAuth();
      await gdriveSave(gdriveState.accessToken, store);
      setStatus("✓ Saved to Google Drive");
    } catch(e) { setStatus("Drive error: "+e.message.slice(0,60)); }
    setGdriveBusy(false);
  }, [store]);

  var handleGDriveLoad = useCallback(async function() {
    setGdriveBusy(true); setStatus("Loading from Google Drive...");
    try {
      await gdriveAuth();
      var data = await gdriveLoad(gdriveState.accessToken);
      if (data && data.sessions) {
        updateStore(function() { return data; });
        setStatus("✓ Loaded from Google Drive ("+data.sessions.length+" sessions)");
      } else { setStatus("No backup found on Drive."); }
    } catch(e) { setStatus("Drive error: "+e.message.slice(0,60)); }
    setGdriveBusy(false);
  }, []);

  // ─── Import/Export ───
  function handleExport() { downloadBackup(store); setStatus("✓ Downloaded"); }
  function handleImport() {
    try {
      var parsed = JSON.parse(importTxt);
      if (parsed.sessions) { updateStore(function(){return parsed;}); setStatus("✓ Imported "+parsed.sessions.length+" sessions"); setImportTxt(""); setShowImport(false); }
    } catch(e) { setStatus("Invalid JSON."); }
  }

  // ─── Derived ───
  var syn = synthesize(sessions);
  var themeEntries = Object.entries(syn.themeCount).sort(function(a,b){return b[1]-a[1];});
  var entityEntries = Object.entries(syn.entityCount).sort(function(a,b){return b[1]-a[1];});
  var domainEntries = Object.entries(syn.domainCount).sort(function(a,b){return b[1]-a[1];});

  // Briefing: from persisted cross-session reports
  var briefingReports = store.briefingReports || [];
  var currentBriefing = briefingReports[briefingIdx] || null;

  // Trend: from persisted reports
  var currentTrend = trendReports[trendIdx] || null;

  // ═════════════════ VIEWS ═════════════════

  // Staleness calculation
  var stalenessDays = daysSinceIngest(store.lastIngestDate);
  var isStale = stalenessDays >= 3;
  var lastIngestLabel = store.lastIngestDate ? new Date(store.lastIngestDate).toLocaleDateString("en-US",{month:"short",day:"numeric",year:"numeric"})+" ("+stalenessDays+"d ago)" : "never";

  var IngestView = (
    <div style={{maxWidth:640}}>
      {/* Staleness warning */}
      {isStale && sCount > 0 && (
        <div className="fade-in" style={{padding:"12px 14px",background:stalenessDays>=7?c.rdS:c.amS,border:"1px solid "+(stalenessDays>=7?c.rd:c.am)+"33",borderRadius:"6px",marginBottom:"12px",fontSize:"12px",lineHeight:1.6}}>
          <span style={{fontFamily:c.mono,fontSize:"10px",color:stalenessDays>=7?c.rd:c.am,textTransform:"uppercase",letterSpacing:"0.08em"}}>{stalenessDays >= 7 ? "⚠ Intel is stale" : "📬 Time to refresh"}</span>
          <div style={{color:c.tx,marginTop:"4px"}}>Last ingest was <strong>{stalenessDays} days ago</strong>. Fetch from Gmail or paste your latest alerts.</div>
        </div>
      )}
      {sCount === 0 && (
        <div style={{padding:"12px 14px",background:c.acS,border:"1px solid "+c.ac+"22",borderRadius:"6px",marginBottom:"12px",fontSize:"12px",color:c.tx,lineHeight:1.6}}>
          <span style={{fontFamily:c.mono,fontSize:"10px",color:c.ac}}>Welcome</span>
          <div style={{marginTop:"4px"}}>Fetch your Google Alert emails directly, or paste content below to start building your retail media intelligence.</div>
        </div>
      )}

      {/* Gmail Fetch */}
      <div style={{marginBottom:"16px",padding:"16px",background:c.s2,border:"1px solid "+c.br,borderRadius:"8px"}}>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",gap:"10px",flexWrap:"wrap"}}>
          <div>
            <div style={{fontFamily:c.mono,fontSize:"11px",color:c.ac,fontWeight:600,marginBottom:"4px"}}>📧 Fetch from Gmail</div>
            <div style={{fontSize:"11px",color:c.txS,lineHeight:1.5}}>Pull latest Google Alert emails directly.</div>
          </div>
          <div style={{display:"flex",gap:"8px",alignItems:"center",flexShrink:0}}>
            <select value={emailCount} onChange={function(e){setEmailCount(Number(e.target.value));}}
              style={{padding:"6px 8px",background:c.s1,color:c.txS,border:"1px solid "+c.br,borderRadius:"4px",fontFamily:c.mono,fontSize:"10px",outline:"none"}}>
              <option value={5}>5 emails</option>
              <option value={10}>10 emails</option>
              <option value={20}>20 emails</option>
              <option value={30}>30 emails</option>
              <option value={50}>50 emails</option>
            </select>
            <Btn onClick={handleGmailFetch} disabled={gmailBusy||busy}>{gmailBusy?<span className="pulsing">Fetching...</span>:"Fetch"}</Btn>
          </div>
        </div>
      </div>

      {/* Divider */}
      <div style={{display:"flex",alignItems:"center",gap:"12px",marginBottom:"12px"}}>
        <div style={{flex:1,height:"1px",background:c.br}}></div>
        <span style={{fontFamily:c.mono,fontSize:"9px",color:c.txD,textTransform:"uppercase",letterSpacing:"0.1em"}}>or paste manually</span>
        <div style={{flex:1,height:"1px",background:c.br}}></div>
      </div>

      {!hasKey && sCount > 0 && <Card><div style={{fontSize:"11px",color:c.am,fontFamily:c.mono,lineHeight:1.6}}>⚠ No API key — using local analysis. Add key in Settings for Claude synthesis.</div></Card>}
      <div style={{fontSize:"12px",color:c.txS,marginBottom:"8px",lineHeight:1.6}}>
        Paste email content or URLs.{hasKey?" Claude will analyze.":""}
        {store.lastIngestDate && <span style={{fontFamily:c.mono,fontSize:"10px",color:c.txD,marginLeft:"8px"}}>Last: {lastIngestLabel}</span>}
      </div>
      <textarea value={input} onChange={function(e){setInput(e.target.value);}} placeholder="Paste email content or URLs..."
        style={{width:"100%",minHeight:input?"140px":"60px",padding:"14px",background:c.s1,color:c.tx,border:"1px solid "+(input?c.brA:c.br),borderRadius:"6px",fontFamily:c.mono,fontSize:"12px",lineHeight:1.6,resize:"vertical",outline:"none",boxSizing:"border-box"}} />
      {input.trim().length>9 && (
        <div style={{marginTop:"10px"}}>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:"8px"}}>
            <span style={{fontFamily:c.mono,fontSize:"10px",color:c.txD}}>{input.length} chars · {extractURLs(input).length} URLs</span>
            <Btn onClick={handleAnalyze} disabled={busy}>{busy?"Analyzing...":"Analyze →"}</Btn>
          </div>
          {/* Date picker for backdating */}
          <div style={{display:"flex",alignItems:"center",gap:"8px",flexWrap:"wrap"}}>
            <button onClick={function(){setShowDatePicker(!showDatePicker);}} style={{background:"transparent",border:"none",color:showDatePicker?c.ac:c.txD,fontFamily:c.mono,fontSize:"10px",cursor:"pointer",padding:0}}>
              {showDatePicker ? "▾ Content date" : "▸ Set content date (for older articles)"}
            </button>
            {showDatePicker && (
              <div className="fade-in" style={{display:"flex",alignItems:"center",gap:"8px"}}>
                <input type="date" value={contentDateInput} onChange={function(e){setContentDateInput(e.target.value);}}
                  style={{padding:"4px 8px",background:c.s1,color:c.tx,border:"1px solid "+c.br,borderRadius:"4px",fontFamily:c.mono,fontSize:"11px",outline:"none"}} />
                {contentDateInput && <span style={{fontFamily:c.mono,fontSize:"10px",color:c.gn}}>✓ Articles will be dated {new Date(contentDateInput+"T12:00:00").toLocaleDateString("en-US",{month:"short",day:"numeric",year:"numeric"})}</span>}
                {contentDateInput && <button onClick={function(){setContentDateInput("");}} style={{background:"transparent",border:"none",color:c.txD,cursor:"pointer",fontSize:"12px"}}>×</button>}
              </div>
            )}
          </div>
        </div>
      )}
      {/* Add article manually */}
      <div style={{marginTop:"16px"}}>
        <button onClick={function(){setShowAddArticle(!showAddArticle);}} style={{background:"transparent",border:"1px dashed "+c.br,borderRadius:"6px",padding:"10px 14px",color:c.txS,fontFamily:c.mono,fontSize:"11px",cursor:"pointer",width:"100%",textAlign:"left"}}>
          {showAddArticle ? "Cancel" : "+ Add article manually"}
        </button>
        {showAddArticle && (
          <div className="fade-in" style={{marginTop:"10px",padding:"14px",background:c.s1,borderRadius:"6px",border:"1px solid "+c.br}}>
            <input value={addUrl} onChange={function(e){setAddUrl(e.target.value);}} placeholder="Article URL (optional)" style={{width:"100%",padding:"8px 10px",background:c.bg,color:c.tx,border:"1px solid "+c.br,borderRadius:"4px",fontFamily:c.mono,fontSize:"11px",marginBottom:"8px",outline:"none",boxSizing:"border-box"}} />
            <input value={addTitle} onChange={function(e){setAddTitle(e.target.value);}} placeholder="Title (optional if URL provided)" style={{width:"100%",padding:"8px 10px",background:c.bg,color:c.tx,border:"1px solid "+c.br,borderRadius:"4px",fontFamily:c.mono,fontSize:"11px",marginBottom:"8px",outline:"none",boxSizing:"border-box"}} />
            <div style={{display:"flex",alignItems:"center",gap:"8px",marginBottom:"8px"}}>
              <span style={{fontFamily:c.mono,fontSize:"10px",color:c.txD}}>Published:</span>
              <input type="date" value={contentDateInput} onChange={function(e){setContentDateInput(e.target.value);}}
                style={{padding:"4px 8px",background:c.bg,color:c.tx,border:"1px solid "+c.br,borderRadius:"4px",fontFamily:c.mono,fontSize:"11px",outline:"none"}} />
            </div>
            <Btn small onClick={addArticle} disabled={!addUrl&&!addTitle}>Add</Btn>
          </div>
        )}
      </div>
      {sCount>0 && <div style={{marginTop:"16px",padding:"12px 14px",background:c.acG,border:"1px solid "+c.br,borderRadius:"6px",fontFamily:c.mono,fontSize:"11px",color:c.txS}}><span style={{color:c.ac}}>■</span> {sCount} sessions · {syn.totalArticles} articles · {entityEntries.length} entities · {themeEntries.length} themes · {getAllUrls(store).size} unique URLs</div>}
    </div>
  );

  // Briefing with navigation
  var BriefingView = sCount===0 ? <div style={{padding:"48px 0",textAlign:"center",color:c.txD,fontFamily:c.mono,fontSize:"12px"}}>No data yet.</div> : (
    <div style={{display:"flex",flexDirection:"column",gap:"12px",maxWidth:720}}>
      {/* Generate button */}
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",flexWrap:"wrap",gap:"8px"}}>
        <span style={{fontFamily:c.mono,fontSize:"10px",color:c.txD}}>{briefingReports.length} briefing{briefingReports.length!==1?"s":""} · {syn.totalArticles} articles across {sCount} sessions</span>
        <Btn onClick={handleBriefing} disabled={briefingBusy||!sCount||!hasKey}>{briefingBusy?<span className="pulsing">Generating...</span>:"Generate Briefing"}</Btn>
      </div>
      {!hasKey && <Card><div style={{fontSize:"11px",color:c.am,fontFamily:c.mono,lineHeight:1.6}}>Add API key in Settings to generate briefings. Stats from local analysis shown below.</div></Card>}

      {/* Briefing navigator */}
      {briefingReports.length > 0 && (
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",fontFamily:c.mono,fontSize:"11px"}}>
          <button onClick={function(){setBriefingIdx(Math.min(briefingIdx+1,briefingReports.length-1));}} disabled={briefingIdx>=briefingReports.length-1} style={{background:"transparent",border:"none",color:briefingIdx>=briefingReports.length-1?c.txD:c.ac,cursor:"pointer",fontSize:"14px"}}>◀</button>
          <span style={{color:c.txS}}>Briefing {briefingReports.length-briefingIdx} of {briefingReports.length} · {currentBriefing?new Date(currentBriefing.date).toLocaleDateString("en-US",{month:"short",day:"numeric",year:"numeric"}):""}
            {currentBriefing&&currentBriefing.snapshot?" · "+currentBriefing.snapshot.totalArticles+" articles":""}</span>
          <button onClick={function(){setBriefingIdx(Math.max(briefingIdx-1,0));}} disabled={briefingIdx<=0} style={{background:"transparent",border:"none",color:briefingIdx<=0?c.txD:c.ac,cursor:"pointer",fontSize:"14px"}}>▶</button>
        </div>
      )}

      {/* Rich briefing content */}
      {currentBriefing && currentBriefing.data && <>
        {currentBriefing.data.executive_summary && (
          <Card><Lbl>Executive Summary</Lbl><div style={{fontSize:"13.5px",lineHeight:1.85,whiteSpace:"pre-wrap"}}>{currentBriefing.data.executive_summary}</div></Card>
        )}

        {currentBriefing.data.market_dynamics && (
          <Card><Lbl color={c.vi}>Market Dynamics</Lbl><div style={{fontSize:"13px",lineHeight:1.8,color:c.txS,whiteSpace:"pre-wrap"}}>{currentBriefing.data.market_dynamics}</div></Card>
        )}

        {currentBriefing.data.key_developments && currentBriefing.data.key_developments.length > 0 && (
          <Card><Lbl color={c.am}>Key Developments</Lbl>
            {currentBriefing.data.key_developments.map(function(d,i){return (
              <div key={i} style={{padding:"10px 0",borderTop:i>0?"1px solid "+c.br:"none"}}>
                <div style={{fontSize:"13px",fontWeight:600,marginBottom:"4px"}}>{d.headline}</div>
                <div style={{fontSize:"12px",color:c.txS,lineHeight:1.6,marginBottom:"4px"}}>{d.analysis}</div>
                <div>{(d.entities||[]).map(function(e){return <Tag key={e} color={c.txS} bg={c.s1}>{e}</Tag>;})}</div>
              </div>
            );})}
          </Card>
        )}

        {currentBriefing.data.strategic_implications && (
          <Card><Lbl color={c.ac}>Strategic Implications (for builders)</Lbl><div style={{fontSize:"13px",lineHeight:1.8,color:c.txS,whiteSpace:"pre-wrap"}}>{currentBriefing.data.strategic_implications}</div></Card>
        )}

        {currentBriefing.data.competitive_landscape && (
          <Card><Lbl color={c.gn}>Competitive Landscape</Lbl><div style={{fontSize:"13px",lineHeight:1.8,color:c.txS,whiteSpace:"pre-wrap"}}>{currentBriefing.data.competitive_landscape}</div></Card>
        )}

        {currentBriefing.data.action_items && currentBriefing.data.action_items.length > 0 && (
          <div style={{padding:"16px",background:"linear-gradient(135deg,"+c.acG+","+c.viS+")",border:"1px solid "+c.brA,borderRadius:"6px",marginBottom:"12px"}}>
            <Lbl>⚡ Action Items</Lbl>
            {currentBriefing.data.action_items.map(function(a,i){return <div key={i} style={{fontSize:"13px",padding:"6px 0",lineHeight:1.6,display:"flex",gap:"10px"}}><span style={{fontFamily:c.mono,color:c.ac,fontSize:"11px",flexShrink:0}}>{String(i+1).padStart(2,"0")}</span><span>{a}</span></div>;})}
          </div>
        )}

        <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit, minmax(260px, 1fr))",gap:"10px"}}>
          {currentBriefing.data.opportunities && currentBriefing.data.opportunities.length > 0 && (
            <Card><Lbl color={c.gn}>Opportunities</Lbl>
              {currentBriefing.data.opportunities.map(function(o,i){return <div key={i} style={{fontSize:"12px",color:c.tx,padding:"5px 0",lineHeight:1.5,borderTop:i>0?"1px solid "+c.br:"none"}}>↗ {o}</div>;})}
            </Card>
          )}
          {currentBriefing.data.risk_factors && currentBriefing.data.risk_factors.length > 0 && (
            <Card><Lbl color={c.rd}>Risk Factors</Lbl>
              {currentBriefing.data.risk_factors.map(function(r,i){return <div key={i} style={{fontSize:"12px",color:c.tx,padding:"5px 0",lineHeight:1.5,borderTop:i>0?"1px solid "+c.br:"none"}}>⚠ {r}</div>;})}
            </Card>
          )}
        </div>
      </>}

      {/* Always show current stats */}
      <Card>
        <Lbl>Current Sentiment · {syn.totalArticles} articles</Lbl>
        <div style={{display:"flex",height:"8px",borderRadius:"4px",overflow:"hidden",background:c.br}}>
          {syn.sentiments.positive>0&&<div style={{width:(syn.sentiments.positive/syn.totalArticles*100)+"%",background:c.gn}}/>}
          {syn.sentiments.neutral>0&&<div style={{width:(syn.sentiments.neutral/syn.totalArticles*100)+"%",background:c.txD}}/>}
          {syn.sentiments.negative>0&&<div style={{width:(syn.sentiments.negative/syn.totalArticles*100)+"%",background:c.rd}}/>}
        </div>
        <div style={{display:"flex",justifyContent:"space-between",marginTop:"6px",fontFamily:c.mono,fontSize:"10px"}}>
          <span style={{color:c.gn}}>pos {syn.sentiments.positive}</span>
          <span style={{color:c.txD}}>neu {syn.sentiments.neutral}</span>
          <span style={{color:c.rd}}>neg {syn.sentiments.negative}</span>
        </div>
      </Card>
      <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit, minmax(180px, 1fr))",gap:"10px"}}>
        <Card><Lbl color={c.vi}>Top Themes</Lbl>{themeEntries.slice(0,6).map(function(p){return <div key={p[0]} style={{fontSize:"12px",padding:"4px 0",display:"flex",justifyContent:"space-between"}}><span>{p[0]}</span><span style={{fontFamily:c.mono,fontSize:"10px",color:c.txD}}>{p[1]}</span></div>;})}</Card>
        <Card><Lbl color={c.gn}>Top Entities</Lbl>{entityEntries.slice(0,6).map(function(p){return <div key={p[0]} style={{fontSize:"12px",padding:"4px 0",display:"flex",justifyContent:"space-between"}}><span>{p[0]}</span><span style={{fontFamily:c.mono,fontSize:"10px",color:c.txD}}>{p[1]}</span></div>;})}</Card>
      </div>
    </div>
  );

  // Trends with navigation + persistence
  var TrendsView = (
    <div style={{display:"flex",flexDirection:"column",gap:"12px",maxWidth:720}}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",flexWrap:"wrap",gap:"8px"}}>
        <span style={{fontFamily:c.mono,fontSize:"10px",color:c.txD}}>{trendReports.length} report{trendReports.length!==1?"s":""} · {sCount} sessions</span>
        <Btn onClick={handleTrends} disabled={trendBusy||!sCount||!hasKey}>{trendBusy?"Synthesizing...":"Generate Trends"}</Btn>
      </div>
      {!hasKey && <Card><div style={{fontSize:"11px",color:c.am,fontFamily:c.mono}}>Add API key in Settings to enable.</div></Card>}
      {trendReports.length>0 && (
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",fontFamily:c.mono,fontSize:"11px"}}>
          <button onClick={function(){setTrendIdx(Math.min(trendIdx+1,trendReports.length-1));}} disabled={trendIdx>=trendReports.length-1} style={{background:"transparent",border:"none",color:trendIdx>=trendReports.length-1?c.txD:c.ac,cursor:"pointer",fontSize:"14px"}}>◀</button>
          <span style={{color:c.txS}}>Report {trendReports.length-trendIdx} of {trendReports.length} · {currentTrend?new Date(currentTrend.date).toLocaleDateString("en-US",{month:"short",day:"numeric",year:"numeric"}):""}</span>
          <button onClick={function(){setTrendIdx(Math.max(trendIdx-1,0));}} disabled={trendIdx<=0} style={{background:"transparent",border:"none",color:trendIdx<=0?c.txD:c.ac,cursor:"pointer",fontSize:"14px"}}>▶</button>
        </div>
      )}
      {currentTrend && currentTrend.snapshot && (
        <div style={{fontFamily:c.mono,fontSize:"10px",color:c.txD,padding:"6px 0"}}>Snapshot: {currentTrend.snapshot.totalArticles} articles across {currentTrend.snapshot.totalSessions} sessions</div>
      )}
      {currentTrend && currentTrend.data ? <>
        {currentTrend.data.weekly_briefing && <Card><Lbl>Executive Briefing</Lbl><div style={{fontSize:"13px",lineHeight:1.85,whiteSpace:"pre-wrap"}}>{currentTrend.data.weekly_briefing}</div></Card>}
        {(currentTrend.data.trend_lines||[]).map(function(tr,i){var col=tr.trajectory==="accelerating"?c.gn:tr.trajectory==="emerging"?c.vi:tr.trajectory==="decelerating"?c.rd:c.txS;var bg=tr.trajectory==="accelerating"?c.gnS:tr.trajectory==="emerging"?c.viS:tr.trajectory==="decelerating"?c.rdS:c.s1;return(
          <Card key={i}><div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:"6px",flexWrap:"wrap",gap:"4px"}}><span style={{fontFamily:c.mono,fontSize:"12px",fontWeight:600}}>{tr.theme}</span><Tag color={col} bg={bg}>{tr.trajectory} · {tr.evidence_count}</Tag></div><div style={{fontSize:"12px",color:c.txS,lineHeight:1.6,marginBottom:"6px"}}>{tr.narrative}</div><div>{(tr.key_players||[]).map(function(p){return <Tag key={p} color={c.txS} bg={c.s1}>{p}</Tag>;})}</div></Card>
        );})}
        {currentTrend.data.connections&&currentTrend.data.connections.length>0&&<Card><Lbl color={c.cy}>Connections</Lbl>{currentTrend.data.connections.map(function(x,i){return <div key={i} style={{fontSize:"12px",padding:"3px 0",lineHeight:1.5}}>↔ {x}</div>;})}</Card>}
        {currentTrend.data.contradictions&&currentTrend.data.contradictions.length>0&&<Card><Lbl color={c.rd}>Contradictions</Lbl>{currentTrend.data.contradictions.map(function(x,i){return <div key={i} style={{fontSize:"12px",padding:"3px 0"}}>⚡ {x}</div>;})}</Card>}
        {currentTrend.data.blind_spots&&currentTrend.data.blind_spots.length>0&&<Card><Lbl color={c.am}>Blind Spots</Lbl>{currentTrend.data.blind_spots.map(function(x,i){return <div key={i} style={{fontSize:"12px",padding:"3px 0"}}>◌ {x}</div>;})}</Card>}
      </> : !trendReports.length && sCount>0&&hasKey ? <div style={{padding:"48px 0",textAlign:"center",color:c.txD,fontFamily:c.mono,fontSize:"12px"}}>Tap "Generate Trends" to create a report.</div> : null}
    </div>
  );

  // Graph
  var GraphView = (function(){var mE=entityEntries.length>0?entityEntries[0][1]:1,mT=themeEntries.length>0?themeEntries[0][1]:1,mD=domainEntries.length>0?domainEntries[0][1]:1;return entityEntries.length===0&&themeEntries.length===0?<div style={{padding:"48px 0",textAlign:"center",color:c.txD,fontFamily:c.mono,fontSize:"12px"}}>No data.</div>:(
    <div style={{display:"flex",flexDirection:"column",gap:"12px"}}>
      {/* Domain breakdown */}
      {domainEntries.length>0 && <Card><Lbl color={c.am}>Domains · {domainEntries.length}</Lbl><div style={{display:"flex",flexWrap:"wrap",gap:"8px"}}>{domainEntries.map(function(p){var domainDef=DOMAINS[p[0]];var label=domainDef?domainDef.name:p[0];return <div key={p[0]} style={{padding:"10px 14px",background:c.bg,border:"1px solid "+c.br,borderRadius:"6px",flex:"1 1 140px",minWidth:"140px"}}><div style={{fontFamily:c.mono,fontSize:"18px",fontWeight:700,color:c[domainDef?domainDef.color:"ac"],marginBottom:"2px"}}>{p[1]}</div><div style={{fontFamily:c.mono,fontSize:"10px",color:c.txS}}>{label}</div><div style={{fontFamily:c.mono,fontSize:"9px",color:c.txD}}>{syn.totalArticles>0?Math.round(p[1]/syn.totalArticles*100)+"% of articles":""}</div></div>;})}</div></Card>}
      {/* Themes + Entities */}
      <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit, minmax(250px, 1fr))",gap:"12px"}}>{[{l:"Entities",d:entityEntries,m:mE,col:c.ac},{l:"Themes",d:themeEntries,m:mT,col:c.vi}].map(function(g){return <Card key={g.l}><Lbl color={g.col}>{g.l} · {g.d.length}</Lbl><div style={{maxHeight:420,overflowY:"auto"}}>{g.d.map(function(p,i){return <div key={i} style={{display:"flex",alignItems:"center",gap:"8px",padding:"4px 0",borderBottom:"1px solid "+c.br}}><span style={{fontSize:"12px",flex:1,minWidth:0,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{p[0]}</span><div style={{width:60,height:3,background:c.br,borderRadius:2,flexShrink:0}}><div style={{width:(p[1]/g.m*100)+"%",height:"100%",background:g.col,borderRadius:2,opacity:0.7}}/></div><span style={{fontFamily:c.mono,fontSize:"10px",color:c.txD,width:18,textAlign:"right",flexShrink:0}}>{p[1]}</span></div>;})}</div></Card>;})}</div>
    </div>);})();

  // Raw with delete
  var RawView = <div style={{display:"flex",flexDirection:"column",gap:"8px"}}>{sCount===0&&<div style={{padding:"48px 0",textAlign:"center",color:c.txD,fontFamily:c.mono,fontSize:"12px"}}>No data.</div>}{sessions.map(function(s){var open=expanded===s.id;return(
    <div key={s.id} style={{background:c.s2,border:"1px solid "+c.br,borderRadius:"6px",overflow:"hidden"}}>
      <div onClick={function(){setExpanded(open?null:s.id);}} style={{padding:"12px 14px",cursor:"pointer",display:"flex",justifyContent:"space-between",alignItems:"center"}}>
        <span style={{fontFamily:c.mono,fontSize:"11px",color:c.ac}}>{new Date(getContentDate(s)).toLocaleDateString("en-US",{month:"short",day:"numeric",year:"numeric"})}{s.source==="claude"?" ✦":s.source==="manual"?" ✎":s.source&&s.source.indexOf("gmail")>-1?" 📧":""}{s.contentDate&&s.contentDate!==s.date?<span style={{color:c.txD,fontSize:"9px",marginLeft:"6px"}}>ingested {new Date(s.date).toLocaleDateString("en-US",{month:"short",day:"numeric"})}</span>:""}</span>
        <div style={{display:"flex",gap:"6px",alignItems:"center"}}><span style={{fontFamily:c.mono,fontSize:"10px",color:c.txD}}>{(s.articles||[]).length} articles</span><span style={{color:c.txD,fontSize:"11px",transform:open?"rotate(90deg)":"none",transition:"transform 0.15s",display:"inline-block"}}>▶</span></div>
      </div>
      {open&&<div style={{padding:"0 14px 12px",borderTop:"1px solid "+c.br}}>{(s.articles||[]).map(function(a,ai){return <ArticleRow key={a.id||ai} article={a} last={ai===s.articles.length-1} onDelete={function(aid){deleteArticle(s.id,aid);}}/>;})}</div>}
    </div>);})}</div>;

  // Settings
  var SettingsView = (
    <div style={{maxWidth:500}}>
      <Card>
        <Lbl>Anthropic API Key</Lbl>
        <div style={{fontSize:"12px",color:c.txS,lineHeight:1.6,marginBottom:"10px"}}>For Claude synthesis. Stored locally. <a href="https://console.anthropic.com/" target="_blank" style={{color:c.ac}}>Get one here</a>.</div>
        <input type="password" value={apiKey} onChange={function(e){var v=e.target.value;setApiKeyState(v);saveSetting(KEY_KEY,v);}} placeholder="sk-ant-..." style={{width:"100%",padding:"10px 12px",background:c.s1,color:c.tx,border:"1px solid "+c.br,borderRadius:"6px",fontFamily:c.mono,fontSize:"12px",outline:"none",boxSizing:"border-box"}} />
        {hasKey&&<div style={{marginTop:"6px",fontFamily:c.mono,fontSize:"10px",color:c.gn}}>✓ Key saved</div>}
      </Card>
      <Card>
        <Lbl color={c.cy}>Google Drive Backup</Lbl>
        <div style={{fontSize:"12px",color:c.txS,lineHeight:1.6,marginBottom:"10px"}}>Save and restore your intelligence data to Google Drive.</div>
        <div style={{display:"flex",gap:"8px",flexWrap:"wrap"}}>
          <Btn small ghost onClick={handleGDriveSave} disabled={gdriveBusy}>Save to Drive</Btn>
          <Btn small ghost onClick={handleGDriveLoad} disabled={gdriveBusy}>Load from Drive</Btn>
        </div>
      </Card>
      <Card>
        <Lbl color={c.am}>Local Backup</Lbl>
        <div style={{display:"flex",gap:"8px",flexWrap:"wrap"}}>
          {sCount>0&&<Btn small ghost onClick={handleExport}>Download JSON</Btn>}
          <Btn small ghost onClick={function(){setShowImport(!showImport);}}>{showImport?"Cancel":"Import JSON"}</Btn>
          {sCount>0&&<Btn small danger onClick={function(){if(confirm("Clear all data?")){updateStore(function(){return emptyStore();});setStatus("Cleared.");}}}>Clear All</Btn>}
        </div>
        {showImport&&<div style={{marginTop:"10px"}}><textarea value={importTxt} onChange={function(e){setImportTxt(e.target.value);}} placeholder="Paste exported JSON..." style={{width:"100%",minHeight:"80px",padding:"12px",background:c.s1,color:c.tx,border:"1px solid "+c.br,borderRadius:"6px",fontFamily:c.mono,fontSize:"11px",resize:"vertical",outline:"none",boxSizing:"border-box"}}/><Btn small onClick={handleImport}>Import</Btn></div>}
      </Card>
    </div>
  );

  // TABS + SHELL
  var tabs=[{id:"ingest",label:"Ingest",s:"+"},{id:"briefing",label:"Brief",s:"◆"},{id:"trends",label:"Trends",s:"↗"},{id:"graph",label:"Graph",s:"◎"},{id:"raw",label:"Raw",s:"≡"},{id:"settings",label:"Settings",s:"⚙"}];

  return (
    <div style={{background:c.bg,color:c.tx,minHeight:"100vh",fontFamily:c.sans}}>
      <div style={{padding:"12px 16px",borderBottom:"1px solid "+c.br,display:"flex",justifyContent:"space-between",alignItems:"center",position:"sticky",top:0,background:c.bg,zIndex:100}}>
        <div style={{display:"flex",alignItems:"baseline",gap:"8px"}}>
          <span style={{fontFamily:c.mono,fontSize:"13px",fontWeight:700}}><span style={{color:c.ac}}>▋</span>Retail Media Intel</span>
        </div>
        <div style={{display:"flex",gap:"8px",alignItems:"center"}}>
          {status&&<span style={{fontFamily:c.mono,fontSize:"10px",color:status.charAt(0)==="\u2713"?c.gn:status.indexOf("rror")>-1?c.rd:c.txS,maxWidth:"220px",overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{status}</span>}
          {!hasKey&&<span onClick={function(){setView("settings");}} style={{fontFamily:c.mono,fontSize:"9px",color:c.am,cursor:"pointer"}}>⚠ key</span>}
        </div>
      </div>
      <div style={{padding:"0 16px",borderBottom:"1px solid "+c.br,display:"flex",overflowX:"auto",scrollbarWidth:"none",position:"sticky",top:"49px",background:c.bg,zIndex:99}}>
        {tabs.map(function(tab){return(
          <button key={tab.id} onClick={function(){setView(tab.id);}} style={{padding:"10px 14px",background:"transparent",border:"none",borderBottom:view===tab.id?"2px solid "+c.ac:"2px solid transparent",color:view===tab.id?c.tx:c.txD,fontFamily:c.mono,fontSize:"11px",fontWeight:view===tab.id?600:400,cursor:"pointer",display:"flex",gap:"5px",alignItems:"center",whiteSpace:"nowrap",flexShrink:0}}>
            <span style={{fontSize:"9px",opacity:view===tab.id?1:0.4}}>{tab.s}</span>{tab.label}
          </button>);})}
      </div>
      <div style={{padding:"16px",maxWidth:800}}>
        {view==="ingest"&&IngestView}
        {view==="briefing"&&BriefingView}
        {view==="trends"&&TrendsView}
        {view==="graph"&&GraphView}
        {view==="raw"&&RawView}
        {view==="settings"&&SettingsView}
      </div>
      {/* Footer */}
      <div style={{padding:"24px 16px",borderTop:"1px solid "+c.br,marginTop:"40px",fontFamily:c.mono,fontSize:"10px",color:c.txD,lineHeight:2,maxWidth:800}}>
        <div>Retail Media Intel — Intelligence from your Google Alerts.</div>
        <div style={{display:"flex",gap:"16px",flexWrap:"wrap",marginTop:"4px"}}>
          <a href="https://patrickthoffman.com/research/tools/retail-intel-hub/privacy" style={{color:c.txS,textDecoration:"none",borderBottom:"1px solid "+c.br}}>Privacy Policy</a>
          <a href="https://patrickthoffman.com/research/tools/retail-intel-hub/terms" style={{color:c.txS,textDecoration:"none",borderBottom:"1px solid "+c.br}}>Terms of Service</a>
          <a href="https://patrickthoffman.com" style={{color:c.txS,textDecoration:"none",borderBottom:"1px solid "+c.br}}>patrickthoffman.com</a>
        </div>
        <div style={{marginTop:"4px"}}>&copy; 2026 Patrick Hoffman</div>
      </div>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App/>);
</script>
</body>
</html>

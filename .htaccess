# BEGIN Error Handlers for Wordpress mod_rewrite and Zotero WebDAV compatibility
ErrorDocument 401 /401.html
ErrorDocument 403 /403.html
ErrorDocument 404 /404.html

# END Error Handlers

# BEGIN Security — deny sensitive files (secrets, VCS, deploy scripts)
# Blocks dotfiles / dot-directories (.git, .env.deploy, .gitignore, .dh-diag)
# and shell/backup files from ever being served. Returns 403 (see ErrorDocument
# above). .well-known is explicitly allowed so ACME/SSL renewals keep working.

# Disable auto-generated directory listings site-wide (info disclosure).
# Directories with an index file still serve it; directories without one now
# return 403 instead of listing their contents.
Options -Indexes

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteRule "(?:^|/)\.(?!well-known/)" - [F,L]
RewriteRule "\.(sh|bak|old)(?:$|/)" - [F,L]
</IfModule>
# Belt-and-suspenders filename match if mod_rewrite is unavailable
<FilesMatch "(?i)(^\.|\.sh$)">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>
# END Security

# BEGIN Legacy redirects
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteRule ^books/product-manager-v2(/.*)?$ /books/product-manager$1 [R=301,L]
</IfModule>
# END Legacy redirects

# BEGIN Canonical URL redirect (index.html -> directory root)
# Sends any request that explicitly asks for .../index.html to the clean
# directory URL instead, so search engines see one canonical URL per page
# rather than two (e.g. /index.html and /). THE_REQUEST (not REQUEST_URI)
# is used so this only fires for the browser's literal request line, not
# for Apache's internal DirectoryIndex rewrite that serves index.html for "/".
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteCond %{THE_REQUEST} /index\.html[?\s] [NC]
RewriteRule ^(.*?)index\.html$ /$1 [R=301,L]
</IfModule>
# END Canonical URL redirect

# BEGIN Extensionless URLs (e.g. /writing/instrumented-match)
# Pairs with the canonical redirect above so every page has exactly one
# canonical URL. Two rules:
# 1. Any *.html request (other than .../index.html, already handled above)
#    is permanently redirected to the extensionless URL.
# 2. The extensionless URL is then served internally from the real .html
#    file on disk, so dropping ".html" from any link never 404s.
<IfModule mod_rewrite.c>
RewriteEngine On

RewriteCond %{THE_REQUEST} /([^.\s]+)\.html[?\s] [NC]
RewriteRule ^ /%1 [R=301,L]

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [L]
</IfModule>
# END Extensionless URLs

